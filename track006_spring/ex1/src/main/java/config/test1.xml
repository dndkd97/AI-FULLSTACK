<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
<!-- Vanilla vanilla = new Vanilla() -->
<bean id="vanilla" class="com.company.ioc1.Vanilla"/>
<!-- Chocolate chocolate = new Chocolate() -->
<bean id="chocolate" class="com.company.ioc1.Chocolate"/>

<bean id="shop" class="com.company.ioc1.IceCreamShop">
<property name="shopName" value="SweetHouse"></property>
<property name="iceCream" ref="vanilla"></property>
</bean>
</beans>
